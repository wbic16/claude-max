}

note: Grammar [count] operator [count] motion
Motions: h/l/j/k/w/b/e/0/$
Operators: d/c/y
@enduml@startuml uml6d
enum Phase {
  Meta=1, Requirements=2, Design=3, Source=4,
  Tests=5, Regressions=6, Docs=7, Whitepapers=8, Training=9
  +from_collection(c): Option<Phase>
  +name(): &str
  +short(): &str
  +color(): &str
}

class ArtifactAddr {
  +volume, book, chapter, section, scroll: usize
  +from_coordinate(c): ArtifactAddr
  +to_coordinate(phase): Coordinate
  +display(): String
}

class UmlContext {
  +phase: Option<Phase>
  +artifact: ArtifactAddr
  +from_coordinate(c): UmlContext
}

note: 5D address stable across SDLC phases
Phase --> ArtifactAddr
UmlContext --> Phase
UmlContext --> ArtifactAddr
@enduml@startuml undo
enum EditOp {
  Insert { offset, text }
  Delete { offset, deleted }
  Replace { offset, old_text, new_text }
}

class UndoEngine {
  -undo_stack: Vec<UndoRecord>
  -redo_stack: Vec<UndoRecord>
  +push(record)
  +undo(text): Option<Position>
  +redo(text): Option<Position>
}

note: Work file is navigable phext
x.chapter = edit sequence number
@enduml@startuml tts
class CoordPronunciation {
  +coordinate: Coordinate
  +syllables: Vec<String>
  +pronounce(): String
  +to_ssml(): String
}

note: 3x5x17+1 syllable grid
X: Onset (3: open/voiced/unvoiced)
Y: Vowel (5: a/e/i/o/u)
Z: Coda (17 terminations)
Zero = om
@endumlWeb UI Design
Two binaries: phext-edit (generic) and uml6d-edit (SDLC-aware).@startuml phext_edit
class AppState {
  +lattice: MappedLattice
  +nav: Navigator
  +overview: LatticeOverview
  +file_path: String
  +dirty: bool
}

class HttpServer <<TcpListener>> {
  +handle_request(stream, state)
}

package REST_API {
  GET /api/nav, /api/status, /api/tree
  POST /api/dim, /api/forward, /api/backward
  POST /api/next, /api/prev, /api/goto
  POST /api/update, /api/save, /api/search
  GET /api/zoom/z, /api/zoom/y, /api/zoom/x
  GET /api/scroll/{coord}
}

HttpServer --> AppState
@enduml@startuml uml6d_edit
class ApiUmlContext {
  +phase, phase_short, phase_color: String
  +artifact_addr: String
  +trace: Vec<ApiTraceEntry>
}

class ApiTraceEntry {
  +phase, phase_short, color: String
  +collection: usize
  +populated: bool
}

package UML6D_API {
  POST /api/phase
}

note: Extends phext-edit with phase badge,
trace panel, quick-nav keys, 5D display
@enduml// Core Module -- src/coordinate_ext.rs, src/index.rs// src/coordinate_ext.rs
//
// Dimension enum: Scroll(1) through Library(9)
// CoordinateNav trait: navigate_forward, navigate_backward,
//   dimension_value, set_dimension, with_dimension
// Delimiters: Scroll=0x17 Section=0x18 Chapter=0x19 Book=0x1A
//   Volume=0x1C Collection=0x1D Series=0x1E Shelf=0x1F Library=0x01
//
// navigate_forward: uses built-in break methods
// navigate_backward: set(current-1), reset lower dims
// with_dimension: non-mutating, returns new coordinate// src/index.rs
//
// LatticeIndex::build(buffer): walks byte-by-byte tracking
//   coordinate via delimiter bytes. ScrollSpan{start,end} stored.
//   Coordinates pushed to sorted Vec for binary search.
//
// get(): HashMap O(1) lookup
// next_populated(): binary search forward
// prev_populated(): binary search backward
// dimension_extent(): unique values per dimension// Storage Module -- src/mmap.rs// src/mmap.rs
//
// open(path): mmap read-only, build index, empty overlay
// read_scroll: overlay first (Modified->content, Deleted->None), else mmap span
// write_scroll: index.contains -> Modified, else Inserted
// save: sort all coords, emit delimiters, read overlay||mmap, write temp, rename
//   re-mmap, rebuild index, clear overlay// Navigation Module -- src/navigator.rs, src/cursor.rs// src/navigator.rs
//
// State: position, active_dimension, marks, history + cursor
// select_dimension(i): set active for h/l
// move_forward/backward: CoordinateNav on active dim
// goto: push history, set position
// next/prev_populated: binary search in sorted coords// src/cursor.rs
//
// Position: (line, col) 0-indexed
// from_offset: walk lines to convert
// ScrollCursor: position + selection + sticky_col
// move_left/right: line-clamped
// move_up/down: sticky_col preserved
// word_forward/backward: boundary scan// src/search.rs
//
// search_scroll: hot inner loop, lowercased compare, context extraction
// search_lattice: serial iterate all scrolls
// search_lattice_parallel: rayon par_iter, atomic results
// search_lattice_auto: buffer.len() vs 512KB threshold
// search_coordinates: regex on coord strings// Topology Module -- src/sentron.rs, src/stats.rs// src/sentron.rs
//
// build(pos, index): get all coords, Manhattan distance, sort,
//   take 40 nearest, count backward/forward per dimension
// structural: Library/Shelf/Series/Collection
// sequential: Volume/Book/Chapter/Section// src/stats.rs
//
// ScrollStats::from_bytes: count lines, words, chars
// DimensionDensity::build: bucket by dim value
// sparkline: unicode block chars
// LatticeOverview::build: totals + extents// Editor Module -- src/editor.rs, src/modes/// src/editor.rs
//
// EditorMode trait: handle_key(EditKey, &mut EditContext) -> EditResult
// EditContext: text (String), cursor (ScrollCursor), undo (UndoEngine)
// EditKey: code + ctrl/alt/shift modifiers// src/modes/vim.rs
//
// VimMode: sub_mode, pending, count, command_buf
// handle_normal: digits->count, h/l/j/k->move, d/c/y->operator
// handle_insert: typing, Esc->normal
// handle_command: :w/:q/:wq// src/uml6d.rs
//
// Phase enum: Meta(1)..Training(9)
//   from_collection, name, short, color, all
//
// ArtifactAddr: {volume, book, chapter, section, scroll}
//   from_coordinate, to_coordinate(phase), to_coordinate_with_outer
//
// UmlContext: phase + artifact from any coordinate
// trace_artifact: check each phase at 5D address
// artifacts_in_phase: all addrs in a given phase// src/undo.rs
//
// EditOp: Insert/Delete/Replace
// UndoRecord: op + cursor_before + cursor_after
// UndoEngine: undo_stack + redo_stack
//   push: clear redo, push undo
//   undo: pop, apply inverse, push redo
//   redo: pop, apply forward, push undo
// Phext serialization: x.chapter = sequence number// src/tts.rs
//
// ONSETS: ['', 'b', 'p'] (3)
// VOWELS: ['a','e','i','o','u'] (5)
// CODAS: ['','p','t','k','b','d','g','m','n','s','f','v','l','r','ng','sh','zh'] (17)
// byte_to_syllable: onset[v%3] + vowel[(v/3)%5] + coda[(v/15)%17]
// Zero = 'om'// Web UI -- src/bin/phext_edit.rs, src/bin/uml6d_edit.rs// src/bin/phext_edit.rs
//
// AppState: lattice + nav + overview + file_path + dirty
// TcpListener on port, thread::spawn per connection
// match (method, path) to API handlers
// INDEX_HTML: ~700 lines embedded SPA
// API: /api/nav, /api/dim, /api/forward, /api/backward,
//   /api/next, /api/prev, /api/goto, /api/base,
//   /api/update, /api/save, /api/search, /api/tree,
//   /api/zoom/*, /api/scroll/*, /api/phexts, /api/open// src/bin/uml6d_edit.rs
//
// Extends phext-edit with:
//   ApiUmlContext: phase, phase_short, phase_color, artifact_addr, trace
//   POST /api/phase: change collection at fixed 5D address
//   Frontend: phase badge, trace panel (T), phase picker (p),
//     quick-nav r/d/s/x/R/D/w/n, UML dim labels in sentronCore Testscoordinate_ext tests:
